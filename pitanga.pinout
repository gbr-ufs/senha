segd1[2]      =   segd1.c_on;
segd1[3]      =   segd1.d_on;
segd1[4]      =   segd1.e_on;
segd1[5]      =   segd1.f_on;
segd1[6]      =   segd1.g_on;

// Display segd2
segd2[0]      =   segd2.a_on;
segd2[1]      =   segd2.b_on;
segd2[2]      =   segd2.c_on;
segd2[3]      =   segd2.d_on;
segd2[4]      =   segd2.e_on;
segd2[5]      =   segd2.f_on;
segd2[6]      =   segd2.g_on;

// Display segd3
segd3[0]      =   segd3.a_on;
