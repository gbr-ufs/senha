// Descrição : arquivo de pinagem contendo o mapeamento do módulo top para
// a placa S (S-Board).

//  MODULE PORT       BOARD COMPONENT
clk_3hz       =   clk_3hz;
btn2          =   btn2;
btn1          =   btn1;
btn0          =   btn0;

// Chaves (sw[3:0] = valor hexadecimal a inserir no digito atual)
sw0           =   sw0;
sw1           =   sw1;
sw2           =   sw2;
sw3           =   sw3;
sw4           =   sw4;
sw5           =   sw5;
sw6           =   sw6;
sw7           =   sw7;
sw8           =   sw8;
sw9           =   sw9;

// LEDs indicadores
led0          =   led0;
led1          =   led1;
led2          =   led2;
led3          =   led3;
led4          =   led4;
led5          =   led5;
led6          =   led6;
led7          =   led7;
led8          =   led8;
led9          =   led9;

// Display segd0 (digito das unidades)
segd0[0]      =   segd0.a_on;
segd0[1]      =   segd0.b_on;
segd0[2]      =   segd0.c_on;
segd0[3]      =   segd0.d_on;
segd0[4]      =   segd0.e_on;
segd0[5]      =   segd0.f_on;
segd0[6]      =   segd0.g_on;

// Display segd1
segd1[0]      =   segd1.a_on;
